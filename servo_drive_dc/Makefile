## Embedded Systems Laboratory 2015 - Raimarius Tolentino Delgado


## Makefile
#######################################################################################################
CFLAGS_OPTIONS = -Wall -D_GNU_SOURCE  

INC_ECAT = /opt/etherlab/include
LIB_ECAT  = /opt/etherlab/lib
CFLAGS = $(CFLAGS_OPTIONS) -I$(INC_ECAT) -I.. -I.
LDFLAGS	 = -lm -lrt -pthread -L$(LIB_ECAT) -lethercat

SOURCES	= ./cia402_basic.c \
          ../driver.cpp \
		  

CUR_DIR = ./
OBJ_DIR = obj
OUT_DIR = bin
OUT	= cia402_basic.out


CC = $(CROSS_COMPILE)gcc
# c++ compiler -> CXX
CXX = $(CROSS_COMPILE)g++ 

LD = $(CROSS_COMPILE)ld
AS = $(CROSS_COMPILE)as

CHMOD	= /bin/chmod
MKDIR	= /bin/mkdir
ECHO	= echo
RM	= /bin/rm

#######################################################################################################
OBJECTS = $(addprefix $(OBJ_DIR)/, $(notdir $(patsubst %.c, %.o, $(patsubst %.cpp, %.o, $(SOURCES)))))
#######################################################################################################
vpath %.c  $(CUR_DIR)
vpath %.cpp $(CUR_DIR) ../
#######################################################################################################

all: $(OUT_DIR)/$(OUT)
	@$(ECHO) BUILD DONE.

$(OUT_DIR)/$(OUT): $(OBJECTS) #./obj/cia402_basic.o
	@$(MKDIR) -p $(OUT_DIR); pwd > /dev/null
	$(CXX) -o $(OUT_DIR)/$(OUT) $(OBJECTS) $(LDFLAGS)

$(OBJ_DIR)/%.o : %.cpp
	@$(MKDIR) -p $(OBJ_DIR); pwd > /dev/null
	$(CXX) -MD $(CFLAGS) -c -o $@ $<

$(OBJ_DIR)/%.o : %.c
	@$(MKDIR) -p $(OBJ_DIR); pwd > /dev/null
	$(CC) -MD $(CFLAGS) -c -o $@ $<

clean:
	$(RM) -rf \
		$(OBJ_DIR)/* \
		$(OBJ_DIR)   \
		$(OUT_DIR)/* \
      	$(OUT_DIR)   \


.PHONY: all clean 
#######################################################################################################
# Include header file dependencies generated by -MD option:
-include $(OBJ_DIR)/*.d